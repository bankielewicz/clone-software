{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "assurance-plan-v2.schema.json",
  "title": "Clone pack v2 assurance plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pack_id", "pack_revision", "risk_profile", "cases"],
  "properties": {
    "schema_version": { "const": "clone-assurance-plan/v2" },
    "pack_id": { "$ref": "#/$defs/id" },
    "pack_revision": { "type": "integer", "minimum": 1 },
    "risk_profile": { "enum": ["local-evaluation", "internal", "customer", "public", "production"] },
    "cases": { "type": "array", "items": { "$ref": "#/$defs/case" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "jsonValue": {
      "oneOf": [
        { "type": ["string", "number", "boolean", "null"] },
        { "type": "array", "items": { "$ref": "#/$defs/jsonValue" } },
        {
          "type": "object",
          "patternProperties": { "^.+$": { "$ref": "#/$defs/jsonValue" } },
          "additionalProperties": false
        }
      ]
    },
    "result": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "patternProperties": { "^.+$": { "$ref": "#/$defs/jsonValue" } },
          "additionalProperties": false
        }
      ]
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "required", "argv", "cwd", "expected_exit", "result"],
      "properties": {
        "id": { "type": "string", "pattern": "^ASSURE-[0-9]{3,}$" },
        "kind": { "enum": ["threat-model", "provenance", "sast", "secret", "dependency", "license", "sbom", "dast", "slsa", "independent-review", "rollback-recovery"] },
        "required": { "type": "boolean" },
        "argv": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "cwd": { "type": "string", "minLength": 1 },
        "timeout_seconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 86400 },
        "expected_exit": { "type": "integer" },
        "artifact_paths": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "result": { "$ref": "#/$defs/result" }
      }
    }
  }
}
