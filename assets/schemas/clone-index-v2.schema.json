{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "clone-index-v2.schema.json",
  "title": "Clone pack v2 trace index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pack_id", "pack_revision", "records"],
  "properties": {
    "schema_version": { "const": "clone-index/v2" },
    "pack_id": { "$ref": "#/$defs/id" },
    "pack_revision": { "type": "integer", "minimum": 1 },
    "records": {
      "type": "array",
      "items": { "$ref": "#/$defs/record" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "artifactId": {
      "type": "string",
      "pattern": "^ART-(?:[0-9]{3,}|(?:CAP|RUN|PAR|ASSURE)-[0-9]{3,}-[0-9]{2,}|PAR-DRIVER-[0-9]{2,}-[0-9]{2,})$"
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "jsonValue": {
      "oneOf": [
        { "type": ["string", "number", "integer", "boolean", "null"] },
        { "type": "array", "items": { "$ref": "#/$defs/jsonValue" } },
        {
          "type": "object",
          "patternProperties": { "^.+$": { "$ref": "#/$defs/jsonValue" } },
          "additionalProperties": false
        }
      ]
    },
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "anchor", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "pattern": "^(?!/)" },
        "anchor": { "type": ["string", "null"] },
        "sha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] }
      }
    },
    "links": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9_-]*$": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      },
      "additionalProperties": false
    },
    "attributes": {
      "type": "object",
      "patternProperties": { "^.+$": { "$ref": "#/$defs/jsonValue" } },
      "additionalProperties": false
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "locator", "links", "applicability", "state", "attributes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": {
          "enum": [
            "BASE", "BLOCK", "ENV", "ART", "E", "CONFLICT", "DEC", "ADR",
            "ACT", "WF", "SURF", "REQ", "IF", "DATA", "SEC", "NFR", "EXC",
            "AC", "TEST", "GATE", "RUN", "GAP", "INV", "CHANGE", "STEP",
            "CAP", "PAR", "ASSURE", "PROV", "ASSET", "THREAT", "CTRL", "FIND", "GAPDEC",
            "COMP", "SBOM", "BUILD", "PROVBLOCK", "STACK", "SCF", "DEP", "SLICE",
            "HALT", "MIG", "ENH", "PRES", "SNAP", "SCOPE"
          ]
        },
        "locator": { "$ref": "#/$defs/locator" },
        "links": { "$ref": "#/$defs/links" },
        "applicability": { "enum": ["MVP", "REQUIRED", "NOT_APPLICABLE", "MIGRATION_RECONCILIATION"] },
        "state": {
          "enum": [
            "DRAFT",
            "PLANNED",
            "NOT_STARTED",
            "IMPLEMENTED_UNVERIFIED",
            "READY",
            "OPEN",
            "BLOCKED",
            "IN_PROGRESS",
            "IMPLEMENTED",
            "VERIFIED",
            "DECLINED",
            "NOT_RUN",
            "PASS",
            "FAIL",
            "ERROR",
            "HOLD",
            "EXCLUDED",
            "MIGRATION_RECONCILIATION"
          ]
        },
        "attributes": { "$ref": "#/$defs/attributes" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "ART" } },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/artifactId" }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "enum": ["SURF", "WF"] } },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "attributes": {
                "type": "object",
                "required": ["disposition"],
                "properties": {
                  "disposition": {
                    "enum": ["EQUIVALENT", "MISSING", "PARTIAL", "DIVERGENT", "EXCLUDED", "UNVERIFIED"]
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "enum": ["CAP", "PAR", "ASSURE", "PRES"] } },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "attributes": {
                "type": "object",
                "required": ["case_sha256"],
                "properties": { "case_sha256": { "$ref": "#/$defs/sha256" } }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "ENH" } },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "attributes": {
                "type": "object",
                "required": ["status", "title", "change_types"],
                "properties": {
                  "status": { "enum": ["DRAFT", "READY", "BLOCKED", "IN_PROGRESS", "IMPLEMENTED", "VERIFIED", "DECLINED"] },
                  "title": { "type": "string", "minLength": 1 },
                  "change_types": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": { "enum": ["feature", "behavior-change", "refactor", "dependency-upgrade", "data-migration", "security-hardening", "operations"] }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "CAP" } },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "links": {
                "type": "object",
                "required": ["environments", "decisions"]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "PAR" } },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "links": {
                "type": "object",
                "required": ["captures"]
              }
            }
          }
        }
      ]
    }
  }
}
