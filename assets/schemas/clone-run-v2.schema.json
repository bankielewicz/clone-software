{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "clone-run-v2.schema.json",
  "title": "Clone pack v2 verification run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "pack_id",
    "pack_revision",
    "reference_baseline_id",
    "clone_revision",
    "clone_diff_sha256",
    "environment_id",
    "gate_id",
    "contract_hashes",
    "argv",
    "started_at",
    "ended_at",
    "expected_exit",
    "observed_exit",
    "result",
    "covered_ids",
    "oracle_ids",
    "artifacts",
    "normalizations",
    "redactions",
    "runner_version"
  ],
  "properties": {
    "schema_version": { "enum": ["clone-run/v2", "clone-manual-run/v2"] },
    "run_id": { "$ref": "#/$defs/id" },
    "pack_id": { "$ref": "#/$defs/id" },
    "pack_revision": { "type": "integer", "minimum": 1 },
    "reference_baseline_id": { "$ref": "#/$defs/id" },
    "clone_revision": { "type": "string", "minLength": 1 },
    "clone_diff_sha256": { "$ref": "#/$defs/nullableSha256" },
    "environment_id": { "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
    "gate_id": { "$ref": "#/$defs/id" },
    "contract_hashes": { "$ref": "#/$defs/contractHashes" },
    "execution_contract": { "$ref": "#/$defs/executionContract" },
    "argv": { "type": "array", "items": { "type": "string" } },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": "string", "format": "date-time" },
    "expected_exit": { "type": "integer" },
    "observed_exit": { "oneOf": [{ "type": "integer" }, { "type": "null" }] },
    "result": { "enum": ["PASS", "FAIL", "BLOCKED", "ERROR"] },
    "covered_ids": { "$ref": "#/$defs/idArray" },
    "oracle_ids": { "$ref": "#/$defs/idArray" },
    "artifacts": { "type": "array", "items": { "$ref": "#/$defs/artifact" } },
    "normalizations": { "type": "array", "items": { "type": "string" } },
    "redactions": { "type": "array", "items": { "$ref": "#/$defs/redactionRule" } },
    "runner_version": { "type": "string", "minLength": 1 },
    "elapsed_ms_context": { "type": "number", "minimum": 0 },
    "diagnostic": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/diagnostic" }
      ]
    },
    "manual_attestation": { "$ref": "#/$defs/manualAttestation" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": { "const": "clone-run/v2" },
          "runner_version": { "enum": ["2.2.0", "2.3.0"] }
        },
        "required": ["schema_version", "runner_version"]
      },
      "then": { "required": ["execution_contract"] }
    }
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "artifactId": {
      "type": "string",
      "pattern": "^ART-(?:[0-9]{3,}|(?:CAP|RUN|PAR|ASSURE)-[0-9]{3,}-[0-9]{2,}|PAR-DRIVER-[0-9]{2,}-[0-9]{2,})$"
    },
    "idArray": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "nullableSha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
    "contractHashes": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[A-Za-z0-9][A-Za-z0-9._:-]*$": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "size", "media_type", "sha256"],
      "properties": {
        "id": { "$ref": "#/$defs/artifactId" },
        "path": { "type": "string", "minLength": 1, "pattern": "^(?!/)" },
        "source_path": { "$ref": "#/$defs/relativePath" },
        "size": { "type": "integer", "minimum": 0 },
        "media_type": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*\\\\).+$"
    },
    "argv": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "cwd": {
      "oneOf": [
        { "const": "." },
        { "$ref": "#/$defs/relativePath" }
      ]
    },
    "environment": {
      "type": "object",
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*$": { "type": "string" }
      },
      "additionalProperties": false
    },
    "integerArray": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "integer" }
    },
    "relativePathArray": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/relativePath" }
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "executionContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "argv",
        "cwd",
        "environment",
        "timeout_seconds",
        "expected_exit",
        "blocked_exit_codes",
        "artifact_paths",
        "fresh_artifact_paths",
        "covered_ids",
        "oracle_ids",
        "normalizations",
        "redactions"
      ],
      "properties": {
        "argv": { "$ref": "#/$defs/argv" },
        "cwd": { "$ref": "#/$defs/cwd" },
        "environment": { "$ref": "#/$defs/environment" },
        "timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
        "expected_exit": { "type": "integer" },
        "blocked_exit_codes": { "$ref": "#/$defs/integerArray" },
        "artifact_paths": { "$ref": "#/$defs/relativePathArray" },
        "fresh_artifact_paths": { "$ref": "#/$defs/relativePathArray" },
        "covered_ids": { "$ref": "#/$defs/idArray" },
        "oracle_ids": { "$ref": "#/$defs/idArray" },
        "normalizations": { "$ref": "#/$defs/stringArray" },
        "redactions": {
          "type": "array",
          "items": { "$ref": "#/$defs/redactionRule" }
        }
      }
    },
    "redactionRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "replacement", "authority_ids"],
      "properties": {
        "pattern": { "type": "string", "minLength": 1 },
        "replacement": { "type": "string" },
        "authority_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string" }
      }
    },
    "manualAttestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["procedure_sha256", "observer", "authority"],
      "properties": {
        "procedure_sha256": { "$ref": "#/$defs/sha256" },
        "observer": { "type": "string", "minLength": 1 },
        "authority": { "type": "string", "minLength": 1 }
      }
    }
  }
}
