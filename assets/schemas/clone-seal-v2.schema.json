{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "clone-seal-v2.schema.json",
  "title": "Clone pack v2 integrity seal",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pack_id", "pack_revision", "profile", "created_at", "verdict", "tool_version", "files", "manifest_sha256"],
  "properties": {
    "schema_version": { "const": "clone-seal/v2" },
    "pack_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "pack_revision": { "type": "integer", "minimum": 1 },
    "profile": { "enum": ["scaffold", "baseline-ready", "spec-ready", "build-ready", "verified-mvp", "gap-plan", "gap-closure", "closed"] },
    "created_at": { "type": "string", "format": "date-time" },
    "verdict": { "const": "PASS" },
    "tool_version": { "type": "string", "minLength": 1 },
    "files": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^(?!/).+$": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "manifest_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
