{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "parity-plan-v2.schema.json",
  "title": "Clone pack v2 parity plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pack_id", "pack_revision", "cases"],
  "properties": {
    "schema_version": { "const": "clone-parity-plan/v2" },
    "pack_id": { "$ref": "#/$defs/id" },
    "pack_revision": { "type": "integer", "minimum": 1 },
    "cases": { "type": "array", "items": { "$ref": "#/$defs/case" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "safeString": {
      "type": "string",
      "pattern": "^(?!.*[\\u0000-\\u001F\\u007F])[\\s\\S]*$"
    },
    "envReference": {
      "type": "string",
      "pattern": "^env:[A-Za-z_][A-Za-z0-9_]*$"
    },
    "environmentMap": {
      "type": "object",
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*$": { "$ref": "#/$defs/safeString" },
        ".*(?:[Tt][Oo][Kk][Ee][Nn]|[Kk][Ee][Yy]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Aa][Uu][Tt][Hh]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]).*": { "$ref": "#/$defs/envReference" }
      },
      "additionalProperties": false
    },
    "jsonValue": {
      "oneOf": [
        { "type": ["string", "number", "boolean", "null"] },
        { "type": "array", "items": { "$ref": "#/$defs/jsonValue" } },
        {
          "type": "object",
          "patternProperties": { "^.+$": { "$ref": "#/$defs/jsonValue" } },
          "additionalProperties": false
        }
      ]
    },
    "normalization": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "artifact_names", "path", "reason", "authority_ids"],
          "properties": {
            "kind": { "const": "json-pointer-remove" },
            "artifact_names": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            },
            "path": { "type": "string", "pattern": "^/" },
            "reason": { "type": "string", "minLength": 1 },
            "authority_ids": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/id" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "artifact_names", "pattern", "replacement", "reason", "authority_ids"],
          "properties": {
            "kind": { "const": "regex-replace" },
            "artifact_names": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            },
            "pattern": { "type": "string", "minLength": 1 },
            "replacement": { "type": "string" },
            "reason": { "type": "string", "minLength": 1 },
            "authority_ids": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/id" }
            }
          }
        }
      ]
    },
    "emptyOptions": {
      "type": "object",
      "additionalProperties": false
    },
    "httpOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["json_artifact_names"],
      "properties": {
        "json_artifact_names": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "performanceOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["absolute_tolerance", "relative_tolerance"],
      "properties": {
        "absolute_tolerance": { "type": "number", "minimum": 0 },
        "relative_tolerance": { "type": "number", "minimum": 0 }
      }
    },
    "artifactPair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference_name", "clone_name"],
      "properties": {
        "reference_name": { "type": "string", "minLength": 1 },
        "clone_name": { "type": "string", "minLength": 1 }
      }
    },
    "customOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["driver_argv", "artifact_pairs", "cwd", "environment", "timeout_seconds"],
      "properties": {
        "driver_argv": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "artifact_pairs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifactPair" } },
        "cwd": { "type": "string", "minLength": 1 },
        "environment": { "$ref": "#/$defs/environmentMap" },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 }
      }
    },
    "perceptualOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["driver_argv", "artifact_pairs", "cwd", "environment", "timeout_seconds", "threshold"],
      "properties": {
        "driver_argv": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "artifact_pairs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifactPair" } },
        "cwd": { "type": "string", "minLength": 1 },
        "environment": { "$ref": "#/$defs/environmentMap" },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "threshold": { "type": "number", "minimum": 0 }
      }
    },
    "result": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "patternProperties": { "^.+$": { "$ref": "#/$defs/jsonValue" } },
          "additionalProperties": false
        }
      ]
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "comparator", "required", "reference_capture_id", "clone_capture_id", "normalizations", "result"],
      "properties": {
        "id": { "type": "string", "pattern": "^PAR-[0-9]{3,}$" },
        "comparator": { "enum": ["exact", "text", "json", "http", "filesystem", "dom", "accessibility", "performance", "perceptual-image", "custom"] },
        "required": { "type": "boolean" },
        "reference_capture_id": { "type": "string", "pattern": "^CAP-[0-9]{3,}$" },
        "clone_capture_id": { "type": "string", "pattern": "^CAP-[0-9]{3,}$" },
        "normalizations": { "type": "array", "items": { "$ref": "#/$defs/normalization" } },
        "options": { "type": "object" },
        "result": { "$ref": "#/$defs/result" }
      },
      "allOf": [
        {
          "if": { "properties": { "comparator": { "enum": ["exact", "text", "json", "filesystem", "dom", "accessibility"] } } },
          "then": { "properties": { "options": { "$ref": "#/$defs/emptyOptions" } } }
        },
        {
          "if": { "properties": { "comparator": { "const": "http" } } },
          "then": { "required": ["options"], "properties": { "options": { "$ref": "#/$defs/httpOptions" } } }
        },
        {
          "if": { "properties": { "comparator": { "const": "performance" } } },
          "then": { "required": ["options"], "properties": { "options": { "$ref": "#/$defs/performanceOptions" } } }
        },
        {
          "if": { "properties": { "comparator": { "const": "perceptual-image" } } },
          "then": { "required": ["options"], "properties": { "options": { "$ref": "#/$defs/perceptualOptions" } } }
        },
        {
          "if": { "properties": { "comparator": { "const": "custom" } } },
          "then": { "required": ["options"], "properties": { "options": { "$ref": "#/$defs/customOptions" } } }
        }
      ]
    }
  }
}
