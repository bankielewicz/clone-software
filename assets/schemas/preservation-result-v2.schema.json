{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "preservation-result-v2.schema.json",
  "title": "Brownfield preservation execution result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "preservation_id",
    "phase",
    "pack_id",
    "pack_revision",
    "enhancement_id",
    "case_sha256",
    "adopted_snapshot_id",
    "candidate_snapshot_id",
    "baseline_result_path",
    "started_at",
    "ended_at",
    "argv",
    "cwd",
    "expected_exit",
    "observed_exit",
    "status",
    "comparator",
    "normalizations",
    "known_failure",
    "diagnostic",
    "details",
    "artifacts",
    "runner_version"
  ],
  "properties": {
    "schema_version": { "const": "clone-preservation-result/v2" },
    "preservation_id": { "type": "string", "pattern": "^PRES-[0-9]{3,}$" },
    "phase": { "enum": ["baseline", "regression"] },
    "pack_id": { "$ref": "#/$defs/id" },
    "pack_revision": { "type": "integer", "minimum": 1 },
    "enhancement_id": { "type": "string", "pattern": "^ENH-[0-9]{3,}$" },
    "case_sha256": { "$ref": "#/$defs/sha256" },
    "adopted_snapshot_id": { "type": "string", "pattern": "^SNAP-[0-9]{3,}$" },
    "candidate_snapshot_id": { "oneOf": [{ "type": "string", "pattern": "^SNAP-[0-9]{3,}$" }, { "type": "null" }] },
    "baseline_result_path": { "oneOf": [{ "$ref": "#/$defs/path" }, { "type": "null" }] },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": "string", "format": "date-time" },
    "argv": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "cwd": { "type": "string", "minLength": 1 },
    "expected_exit": { "type": "integer" },
    "observed_exit": { "type": ["integer", "null"] },
    "status": { "enum": ["PASS", "FAIL", "BLOCKED"] },
    "comparator": { "enum": ["exact", "text", "json"] },
    "normalizations": { "type": "array", "items": { "$ref": "#/$defs/normalization" } },
    "known_failure": { "oneOf": [{ "$ref": "#/$defs/knownFailure" }, { "type": "null" }] },
    "diagnostic": { "oneOf": [{ "$ref": "#/$defs/diagnostic" }, { "type": "null" }] },
    "details": { "type": "array", "items": { "type": "string" } },
    "artifacts": { "type": "array", "items": { "$ref": "#/$defs/artifact" } },
    "runner_version": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": { "properties": { "phase": { "const": "baseline" } }, "required": ["phase"] },
      "then": {
        "properties": {
          "candidate_snapshot_id": { "type": "null" },
          "baseline_result_path": { "type": "null" }
        }
      },
      "else": {
        "properties": {
          "candidate_snapshot_id": { "type": "string", "pattern": "^SNAP-[0-9]{3,}$" },
          "baseline_result_path": { "$ref": "#/$defs/path" }
        }
      }
    }
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "path": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$" },
    "idArray": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "artifact_names", "reason", "authority_ids"],
      "properties": {
        "kind": { "enum": ["regex-replace", "json-pointer-remove"] },
        "artifact_names": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "pattern": { "type": "string", "minLength": 1 },
        "replacement": { "type": "string" },
        "path": { "type": "string", "pattern": "^/" },
        "reason": { "type": "string", "minLength": 1 },
        "authority_ids": { "$ref": "#/$defs/idArray" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "regex-replace" } }, "required": ["kind"] },
          "then": { "required": ["pattern", "replacement"] }
        },
        {
          "if": { "properties": { "kind": { "const": "json-pointer-remove" } }, "required": ["kind"] },
          "then": { "required": ["path"] }
        }
      ]
    },
    "knownFailure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_exit", "expected_stdout_sha256", "expected_stderr_sha256", "reason", "decision_ids"],
      "properties": {
        "expected_exit": { "type": "integer" },
        "expected_stdout_sha256": { "$ref": "#/$defs/sha256" },
        "expected_stderr_sha256": { "$ref": "#/$defs/sha256" },
        "reason": { "type": "string", "minLength": 1 },
        "decision_ids": { "$ref": "#/$defs/idArray" }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "path", "size", "media_type", "sha256"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/path" },
        "size": { "type": "integer", "minimum": 0 },
        "media_type": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
