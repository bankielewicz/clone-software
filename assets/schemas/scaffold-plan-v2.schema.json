{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scaffold-plan-v2.schema.json",
  "title": "Clone pack v2 scaffold plan",
  "type": "object",
  "additionalProperties": false,
  "oneOf": [
    {
      "properties": {
        "profile_id": {
          "enum": ["static-web-esm", "python-src", "typescript-src", "rust-crate"]
        }
      }
    },
    {
      "properties": {
        "profile_id": { "const": "not-applicable" },
        "template": { "const": "not-applicable" },
        "output_root": { "const": "." },
        "required_paths": { "const": [] },
        "commands": {
          "const": {
            "setup": null,
            "test": null,
            "build": null,
            "run": null
          }
        },
        "applied": { "const": false }
      }
    }
  ],
  "required": [
    "schema_version",
    "pack_id",
    "pack_revision",
    "stack_decision_id",
    "profile_id",
    "template",
    "output_root",
    "variables",
    "required_paths",
    "commands",
    "applied"
  ],
  "properties": {
    "schema_version": { "const": "clone-scaffold-plan/v2" },
    "pack_id": { "$ref": "#/$defs/id" },
    "pack_revision": { "type": "integer", "minimum": 1 },
    "stack_decision_id": { "type": "string", "pattern": "^STACK-\\d{3,}$" },
    "profile_id": {
      "enum": ["static-web-esm", "python-src", "typescript-src", "rust-crate", "not-applicable"]
    },
    "template": {
      "enum": ["static-web-esm", "python-src", "typescript-src", "rust-crate", "not-applicable"]
    },
    "output_root": { "type": "string", "minLength": 1 },
    "variables": { "$ref": "#/$defs/variables" },
    "required_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "pattern": "^(?!/)" }
    },
    "commands": { "$ref": "#/$defs/commands" },
    "applied": { "type": "boolean" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "variableValue": { "type": ["string", "number", "boolean", "null"] },
    "variables": {
      "type": "object",
      "patternProperties": { "^[A-Z][A-Z0-9_]*$": { "$ref": "#/$defs/variableValue" } },
      "additionalProperties": false
    },
    "command": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      ]
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "required": ["setup", "test", "build", "run"],
      "properties": {
        "setup": { "$ref": "#/$defs/command" },
        "test": { "$ref": "#/$defs/command" },
        "build": { "$ref": "#/$defs/command" },
        "run": { "$ref": "#/$defs/command" }
      }
    }
  }
}
